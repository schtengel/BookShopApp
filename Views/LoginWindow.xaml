<Window x:Class="BookShopApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookShopApp.Views"
        WindowStartupLocation="CenterScreen"
        Icon="/Images/icon.ico"
        mc:Ignorable="d"
        Title="Авторизация" Height="400" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="32"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="32"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1"
                Grid.Row="1">
            <Image Source="/Images/icon.png"
                   Width="100"/>
            <TextBlock FontSize="24"
           HorizontalAlignment="Center"
           VerticalAlignment="Center">Авторизация</TextBlock>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Grid.Row="2">
            <TextBlock>Логин</TextBlock>
            <TextBox Name="LoginTextBox" Text="{Binding Login,
                UpdateSourceTrigger=PropertyChanged}"
                     FontSize="16"/>
        </StackPanel>
        <StackPanel Grid.Column="1"
            Grid.Row="3">
            <TextBlock>Пароль</TextBlock>
            <PasswordBox Name="PasswordTextBox"
                         FontSize="16"
                         PasswordChanged="PasswordTextBox_PasswordChanged"/>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Grid.Row="4">
            <Button Command="{Binding LoginUserCommand}"
                    Height="32"
                    Margin="0 0">Войти</Button>
            <Button Background="{x:Null}" 
                    Command="{Binding EnterGuestCommand}"
                    Height="24"
                    Margin="0 8"
                    BorderThickness="0">Войти как гость</Button>
        </StackPanel>
    </Grid>
</Window>
