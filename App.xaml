<Application x:Class="BookShopApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BookShopApp"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="MainBackground" Color="#FFF"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#ABCFCE"/>
        <SolidColorBrush x:Key="AccentColor" Color="#546F94"/>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Comic Sans MS"/>
            <Setter Property="Background" Value="{StaticResource MainBackground}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Comic Sans MS"/>
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Padding" Value="8, 0"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
        </Style>

        <Style TargetType="ItemsControl">
            <Setter Property="FontFamily" Value="Comic Sans MS"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Application.Resources>
</Application>
